# Copy this file to ".env" and fill in your own values.
# Restart the dev server after changing env vars.

# Required. Create at https://console.cloud.google.com/ and enable:
#   - Maps JavaScript API
#   - Places API
#   - Geocoding API
# Restrict the key by HTTP referrer (e.g. http://localhost:5173/*) before use.
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional. A Map ID enables Advanced Markers / cloud-based map styling.
# Leave unset to use Google's "DEMO_MAP_ID" during development.
VITE_GOOGLE_MAPS_MAP_ID=
